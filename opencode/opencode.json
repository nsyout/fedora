{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "permission": {
    "external_directory": {
      "*": "ask",
      "~/.config/opencode/**": "allow",
      "~/.dotfiles/**": "allow",
      "~/projects/**": "allow",
      "~/.local/share/opencode/mcp-auth.json": "deny"
    },
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.envrc": "deny",
      "secrets/*": "deny",
      ".dev.vars": "ask",
      "~/.local/share/opencode/mcp-auth.json": "deny"
    },
    "bash": {
      "*": "ask",
      "ast-grep *": "allow",
      "awk *": "allow",
      "basename *": "allow",
      "biome *": "allow",
      "bun *": "allow",
      "cargo *": "allow",
      "cat *": "allow",
      "cloc *": "allow",
      "cp *": "allow",
      "date *": "allow",
      "diff *": "allow",
      "dirname *": "allow",
      "dot *": "allow",
      "du *": "allow",
      "echo *": "allow",
      "fd *": "allow",
      "file *": "allow",
      "find *": "allow",
      "fzf *": "allow",
      "gh *": "allow",
      "gh * approve*": "ask",
      "gh * close*": "ask",
      "gh * comment*": "ask",
      "gh * create*": "ask",
      "gh * delete*": "ask",
      "gh * edit*": "ask",
      "gh * merge*": "ask",
      "gh * reopen*": "ask",
      "gh * review*": "ask",
      "gh repo clone*": "allow",
      "git *": "allow",
      "git push*": "ask",
      "go *": "allow",
      "grep *": "allow",
      "gunzip *": "allow",
      "gzip *": "allow",
      "head *": "allow",
      "hostname": "allow",
      "id": "allow",
      "jq *": "allow",
      "ls *": "allow",
      "make *": "allow",
      "mkdir *": "allow",
      "mv *": "allow",
      "npm *": "allow",
      "pnpm *": "allow",
      "prettier *": "allow",
      "printf *": "allow",
      "pwd": "allow",
      "readlink *": "allow",
      "realpath *": "allow",
      "rg *": "allow",
      "sed *": "allow",
      "shellcheck *": "allow",
      "sort *": "allow",
      "stat *": "allow",
      "stow *": "allow",
      "stylua *": "allow",
      "tail *": "allow",
      "tar *": "allow",
      "tee *": "allow",
      "touch *": "allow",
      "tr *": "allow",
      "tree *": "allow",
      "true": "allow",
      "tsc *": "allow",
      "turbo *": "allow",
      "uname *": "allow",
      "uniq *": "allow",
      "unzip *": "allow",
      "vite *": "allow",
      "vitest *": "allow",
      "wc *": "allow",
      "which *": "allow",
      "whoami": "allow",
      "wl-copy *": "allow",
      "wl-paste *": "allow",
      "xargs *": "ask",
      "xclip *": "allow",
      "yarn *": "allow",
      "z *": "allow",
      "zip *": "allow",
      "zoxide *": "allow"
    },
    "edit": "allow",
    "webfetch": "ask"
  },
  "plugin": [
    "file://{env:HOME}/.config/opencode/plugins/notification.js"
  ]
}
