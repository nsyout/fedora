#!/usr/bin/env bash

set -euo pipefail

resolve_script_path() {
	local source_path="${BASH_SOURCE[0]}"
	while [[ -L "$source_path" ]]; do
		local dir
		dir="$(cd -P "$(dirname "$source_path")" && pwd)"
		source_path="$(readlink "$source_path")"
		[[ "$source_path" != /* ]] && source_path="$dir/$source_path"
	done

	cd -P "$(dirname "$source_path")" && pwd
}

DOTFILES_DIR="${DOTFILES_DIR:-$(resolve_script_path)}"

# --------------------------------------------------------------------------
# Shared libraries
# --------------------------------------------------------------------------

# shellcheck disable=SC1091
source "$DOTFILES_DIR/scripts/lib/common.sh"
# shellcheck disable=SC1091
source "$DOTFILES_DIR/scripts/lib/platform.sh"
# shellcheck disable=SC1091
source "$DOTFILES_DIR/scripts/lib/symlink.sh"
# shellcheck disable=SC1091
source "$DOTFILES_DIR/scripts/lib/packages.sh"
# shellcheck disable=SC1091
source "$DOTFILES_DIR/scripts/lib/plugins.sh"

# Detect platform early -- sets DOT_PLATFORM and DOT_PLATFORM_DIR.
# Asserts Linux; bails on any other OS.
dot_platform_detect || exit 1

# --------------------------------------------------------------------------
# Linux command libraries
# --------------------------------------------------------------------------

LINUX_LIB="$DOTFILES_DIR/scripts/lib/linux"

# shellcheck disable=SC1091
source "$LINUX_LIB/cmd_git.sh"
# shellcheck disable=SC1091
source "$LINUX_LIB/cmd_ssh.sh"
# shellcheck disable=SC1091
source "$LINUX_LIB/cmd_firefox.sh"
# shellcheck disable=SC1091
source "$LINUX_LIB/cmd_wallpaper.sh"
# shellcheck disable=SC1091
source "$LINUX_LIB/cmd_init.sh"
# shellcheck disable=SC1091
source "$LINUX_LIB/cmd_display.sh"
# shellcheck disable=SC1091
source "$LINUX_LIB/cmd_theme.sh"
# shellcheck disable=SC1091
source "$LINUX_LIB/cmd_system.sh"
# shellcheck disable=SC1091
source "$LINUX_LIB/cmd_update.sh"
# shellcheck disable=SC1091
source "$LINUX_LIB/cmd_doctor.sh"

# --------------------------------------------------------------------------
# Usage
# --------------------------------------------------------------------------

usage() {
	cat <<'EOF'
dot - Linux (Fedora/Sway) dotfiles management

Usage:
  dot <command> [subcommand] [options]

Core workflow:
  dot init [--yes] [--dry-run]
  dot symlink                        Link dotfiles into ~/.config
  dot doctor                         Check system status
  dot update [--yes]                 Update system + packages + configs

Integrations:
  dot git setup [--name <n>] [--email <e>] [--default-branch <b>]
                [--signing-key <path>] [--enable-signing|--disable-signing] [--yes]
  dot git status
  dot git signing status|enable|disable|key
  dot ssh configure [--dry-run] [--yes]
  dot ssh sync-yubikey-keys --slot <primary|backup> [--dry-run] [--yes]
  dot ssh status
  dot firefox sync [--dry-run] [--yes]
  dot wallpaper sync|list|set [--pick|--random] [--dry-run]

Packages:
  dot packages sync|check|list

Plugins:
  dot plugins sync                   Clone/update external zsh plugins
  dot plugins list                   Show installed status

Linux:
  dot display add [--dry-run]        Add kanshi profiles for new displays
  dot display list                   Show configured display profiles
  dot system                         Install /etc configs (sudo)
  dot repos                          Configure third-party repositories
  dot theme current|list|set <name>|render

Quality:
  dot qa                             Run local QA checks
  dot security [--history] [--warn-sast]
  dot sast [--strict]

Utility:
  dot link                           Link dot into ~/.local/bin
  dot unlink                         Remove ~/.local/bin/dot symlink
  dot edit                           Open dotfiles directory in $EDITOR
  dot help                           Show this help
EOF
}

# --------------------------------------------------------------------------
# Shared commands
# --------------------------------------------------------------------------

cmd_symlink() {
	local assume_yes=false

	while [[ $# -gt 0 ]]; do
		case "$1" in
		--yes)
			assume_yes=true
			;;
		-h | --help)
			cat <<'EOF'
Usage: dot symlink [--yes]
EOF
			return 0
			;;
		*)
			error "Unknown option for dot symlink: $1"
			return 1
			;;
		esac
		shift
	done

	dot_symlink_apply "$assume_yes"
}

# --------------------------------------------------------------------------
# Utility commands
# --------------------------------------------------------------------------

link_dot() {
	local target="$HOME/.local/bin/dot"
	mkdir -p "$(dirname "$target")"
	ln -sfn "$DOTFILES_DIR/dot" "$target"
	info "Linked dot to $target"
}

unlink_dot() {
	local target="$HOME/.local/bin/dot"
	if [[ -L "$target" ]]; then
		rm "$target"
		info "Removed $target"
		return 0
	fi
	warn "No dot symlink at $target"
}

cmd_edit() {
	"${EDITOR:-nvim}" "$DOTFILES_DIR"
}

# --------------------------------------------------------------------------
# Main dispatch
# --------------------------------------------------------------------------

main() {
	local command="${1:-help}"
	case "$command" in
	-h | --help | help)
		usage
		;;
	symlink)
		shift
		cmd_symlink "$@"
		;;
	init)
		shift
		dot_cmd_init "$@"
		;;
	update)
		shift
		dot_cmd_update "$@"
		;;
	doctor)
		shift
		dot_cmd_doctor "$@"
		;;
	git)
		shift
		dot_cmd_git "$@"
		;;
	ssh)
		shift
		dot_cmd_ssh "$@"
		;;
	firefox)
		shift
		dot_cmd_firefox "$@"
		;;
	wallpaper)
		shift
		dot_cmd_wallpaper "$@"
		;;
	packages)
		shift
		dot_cmd_packages "$@"
		;;
	plugins)
		shift
		local action="${1:-sync}"
		case "$action" in
		sync)
			dot_plugins_sync
			;;
		list)
			dot_plugins_list
			;;
		*)
			error "Usage: dot plugins <sync|list>"
			;;
		esac
		;;
	display)
		shift
		dot_cmd_display "$@"
		;;
	system)
		dot_cmd_system
		;;
	repos)
		dot_cmd_repos
		;;
	theme)
		shift
		dot_cmd_theme "$@"
		;;

	# Quality
	qa)
		shift
		bash "$DOTFILES_DIR/scripts/local-qa.sh" "$@"
		;;
	security)
		shift
		bash "$DOTFILES_DIR/scripts/local-security.sh" "$@"
		;;
	sast)
		shift
		bash "$DOTFILES_DIR/scripts/local-sast.sh" "$@"
		;;

	# Utility
	link)
		link_dot
		;;
	unlink)
		unlink_dot
		;;
	edit)
		cmd_edit
		;;
	*)
		usage
		error "Unknown command: $command"
		exit 1
		;;
	esac
}

main "$@"
