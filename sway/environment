# User environment variables for Sway
# Sourced by /usr/bin/start-sway

# Ensure ~/.local/bin is in PATH (for ghostty, starship, lazygit, etc.)
PATH="$HOME/.local/bin:$PATH"

# Flatpak app directories (so .desktop files show up in rofi)
XDG_DATA_DIRS="/var/lib/flatpak/exports/share:$HOME/.local/share/flatpak/exports/share:${XDG_DATA_DIRS:-/usr/local/share:/usr/share}"

# GTK dark theme
GTK_THEME=Adwaita:dark

# Qt theme (follows GTK if qt5ct/qt6ct not installed)
QT_QPA_PLATFORMTHEME=gtk3

# Application compatibility
_JAVA_AWT_WM_NONREPARENTING=1
